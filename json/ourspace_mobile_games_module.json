{
  "moduleName": "OurSpace Mobile Games Module",
  "version": "site-embedded-json-css-only-v1",
  "moduleMode": "embedded-in-site-mobile-games-page",
  "note": "The module is not a separate HTML page. The games themselves remain separate HTML files loaded into the in-site game frame.",
  "sizing": {
    "siteModuleDefault": "width: min(94vw, 520px)",
    "siteModuleLarge": "width: min(94vw, 760px)",
    "siteModuleWide": "width: min(94vw, 1080px)",
    "siteModuleMinHeight": "min-height: 170px",
    "mobileOverrideUnder860px": "width: calc(100vw - 28px) !important",
    "collapsedBubble": "width: 100px; height: 100px",
    "phoneFrame": "width: min(100%, 320px); aspect-ratio: 9 / 16; border: 10px solid currentColor",
    "gameStage": "width: 100%; min-height: 220px",
    "fullscreenFrame": "position: fixed; inset: 10px"
  },
  "selectors": {
    "moduleRoot": ".ourspace-mobile-games-module",
    "gameSelect": "#ourspaceGameSelect",
    "profileSelect": "#ourspaceGameProfileSelect",
    "launchButton": "#ourspaceLaunchGameBtn",
    "fullscreenButton": "#ourspaceGameFullscreenBtn",
    "directLink": "#ourspaceGameDirectLink",
    "gameFrame": "#ourspaceGameFrame",
    "ledgerBalance": "#ourspaceGameBalance",
    "ledgerHistory": "#ourspaceGameHistory"
  },
  "currencyConfig": {
